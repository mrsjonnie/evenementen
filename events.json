    {
      "title": "Tramhaus 2026 vrijdag",
      "type": "evenement",
      "date": "2026-12-18",
      "time": "",
      "location": "www.vera-groningen.nl",
      "lat": null,
      "lon": null,
      "locationLink": "",
      "cost": "Zie website",
